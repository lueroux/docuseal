<div class="container mx-auto px-4 py-6 max-w-4xl">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-4xl font-bold"><%= @quote.reference_number %></h1>
    <div class="flex gap-2">
      <%= link_to document_quote_path(@quote), class: 'btn btn-outline', target: '_blank' do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        View Document
      <% end %>
      <%= link_to quote_path(@quote, format: :pdf), class: 'btn btn-outline', target: '_blank' do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download PDF
      <% end %>
      <%= link_to 'Edit', edit_quote_path(@quote), class: 'btn btn-primary' %>
      <%= link_to 'Back to Quotes', quotes_path, class: 'btn btn-ghost' %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="stat bg-base-100 shadow">
      <div class="stat-title">Status</div>
      <div class="stat-value text-2xl">
        <span class="badge badge-lg <%= case @quote.status
          when 'draft' then 'badge-ghost'
          when 'sent' then 'badge-info'
          when 'viewed' then 'badge-primary'
          when 'accepted' then 'badge-success'
          when 'declined' then 'badge-error'
          when 'expired' then 'badge-warning'
          end %>">
          <%= @quote.status.titleize %>
        </span>
      </div>
    </div>

    <div class="stat bg-base-100 shadow">
      <div class="stat-title">Total</div>
      <div class="stat-value">£<%= number_with_precision(@quote.total_price, precision: 2) %></div>
    </div>

    <div class="stat bg-base-100 shadow">
      <div class="stat-title">Valid Until</div>
      <div class="stat-value text-2xl"><%= @quote.valid_until&.strftime('%d/%m/%Y') || 'Not set' %></div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-xl mb-6">
    <div class="card-body">
      <h2 class="card-title">Customer</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-base-content/70">Name</p>
          <p class="font-semibold"><%= @quote.customer.name %></p>
        </div>
        <div>
          <p class="text-sm text-base-content/70">Email</p>
          <p class="font-semibold"><%= @quote.customer.email %></p>
        </div>
        <% if @quote.customer.phone.present? %>
          <div>
            <p class="text-sm text-base-content/70">Phone</p>
            <p class="font-semibold"><%= @quote.customer.phone %></p>
          </div>
        <% end %>
        <% if @quote.customer.company.present? %>
          <div>
            <p class="text-sm text-base-content/70">Company</p>
            <p class="font-semibold"><%= @quote.customer.company.name %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if @quote.title.present? %>
    <div class="card bg-base-100 shadow-xl mb-6">
      <div class="card-body">
        <h2 class="card-title"><%= @quote.title %></h2>
      </div>
    </div>
  <% end %>

  <% if @quote.notes.present? %>
    <div class="card bg-base-100 shadow-xl mb-6">
      <div class="card-body">
        <h2 class="card-title">Customer Notes</h2>
        <p class="whitespace-pre-wrap"><%= @quote.notes %></p>
      </div>
    </div>
  <% end %>

  <% if @quote.internal_notes.present? %>
    <div class="card bg-base-100 shadow-xl mb-6 border-2 border-warning">
      <div class="card-body">
        <h2 class="card-title text-warning">Internal Notes</h2>
        <p class="whitespace-pre-wrap"><%= @quote.internal_notes %></p>
      </div>
    </div>
  <% end %>

  <!-- Products Section -->
  <% if @quote.quote_items.any? %>
    <div class="card bg-base-100 shadow-xl mb-6">
      <div class="card-body">
        <h2 class="card-title mb-4">Products (<%= pluralize(@quote.quote_items.count, 'item') %>)</h2>
        
        <div class="overflow-x-auto">
          <table class="table table-zebra">
            <thead>
              <tr>
                <th>Product</th>
                <th class="text-center">Qty</th>
                <th class="text-right">Unit Price</th>
                <th class="text-right">Total</th>
              </tr>
            </thead>
            <tbody>
              <% @quote.quote_items.ordered.each do |item| %>
                <tr>
                  <td>
                    <div class="font-semibold"><%= item.product.name %></div>
                    <div class="text-sm text-base-content/70">
                      <%= item.product.sku %>
                      <% if item.product.brand.present? %>
                        | <%= item.product.brand %>
                      <% end %>
                    </div>
                    <% if item.notes.present? %>
                      <div class="text-xs text-base-content/60 mt-1">
                        <strong>Note:</strong> <%= item.notes %>
                      </div>
                    <% end %>
                  </td>
                  <td class="text-center"><%= item.quantity %></td>
                  <td class="text-right font-mono">
                    £<%= number_with_precision(item.quoted_price, precision: 2, delimiter: ',') %>
                    <% if item.discount_percentage > 0 %>
                      <div class="text-xs text-success">
                        -<%= item.discount_percentage %>% discount
                      </div>
                    <% end %>
                  </td>
                  <td class="text-right font-mono font-semibold">
                    £<%= number_with_precision(item.line_total, precision: 2, delimiter: ',') %>
                  </td>
                </tr>
                
                <% if item.quote_item_options.where(is_selected: true).any? %>
                  <tr class="bg-base-200/50">
                    <td colspan="4" class="text-sm">
                      <div class="pl-4">
                        <strong>Options:</strong>
                        <% item.quote_item_options.where(is_selected: true).each do |option| %>
                          <span class="badge badge-sm badge-ghost ml-2">
                            <%= option.name %> (+£<%= number_with_precision(option.price, precision: 2) %>)
                          </span>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% end %>
            </tbody>
            <tfoot>
              <tr class="font-bold">
                <td colspan="3" class="text-right">Total:</td>
                <td class="text-right font-mono text-lg">
                  £<%= number_with_precision(@quote.calculate_total, precision: 2, delimiter: ',') %>
                </td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>
  <% end %>

  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title">Quote Details</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-base-content/70">Created By</p>
          <p class="font-semibold"><%= @quote.user.first_name %> <%= @quote.user.last_name %></p>
        </div>
        <div>
          <p class="text-sm text-base-content/70">Created</p>
          <p class="font-semibold"><%= @quote.created_at.strftime('%d/%m/%Y %H:%M') %></p>
        </div>
        <% if @quote.sent_at.present? %>
          <div>
            <p class="text-sm text-base-content/70">Sent</p>
            <p class="font-semibold"><%= @quote.sent_at.strftime('%d/%m/%Y %H:%M') %></p>
          </div>
        <% end %>
        <% if @quote.viewed_at.present? %>
          <div>
            <p class="text-sm text-base-content/70">Viewed</p>
            <p class="font-semibold"><%= @quote.viewed_at.strftime('%d/%m/%Y %H:%M') %></p>
          </div>
        <% end %>
        <% if @quote.signed_at.present? %>
          <div>
            <p class="text-sm text-base-content/70">Signed</p>
            <p class="font-semibold"><%= @quote.signed_at.strftime('%d/%m/%Y %H:%M') %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
