<div class="quote-document">
  <%== @document_html %>
</div>

<style>
  @media print {
    .no-print {
      display: none !important;
    }
    
    .page-break {
      page-break-after: always;
    }
  }
  
  .quote-document {
    max-width: 210mm;
    margin: 0 auto;
    padding: 20mm;
    background: white;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  
  .cover-page {
    min-height: 297mm;
  }
  
  .cover-header {
    text-align: center;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 2px solid #94be58;
  }
  
  .cover-header h1 {
    font-size: 36px;
    color: #252525;
    margin-bottom: 10px;
  }
  
  .reference {
    font-size: 18px;
    color: #666;
    margin: 5px 0;
  }
  
  .customer-details {
    margin: 40px 0;
    padding: 20px;
    background: #f5f5f5;
    border-radius: 8px;
  }
  
  .customer-details h2 {
    font-size: 24px;
    margin-bottom: 15px;
    color: #252525;
  }
  
  .attention-of {
    font-size: 14px;
    color: #666;
    font-style: italic;
  }
  
  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
  }
  
  .pricing-table th,
  .pricing-table td {
    padding: 12px;
    text-align: left;
    border-bottom: 1px solid #ddd;
  }
  
  .pricing-table th {
    background: #94be58;
    color: white;
    font-weight: 600;
  }
  
  .pricing-table tfoot td {
    font-weight: 600;
  }
  
  .total-row {
    background: #f5f5f5;
    font-size: 18px;
  }
  
  .item-options,
  .item-notes,
  .item-sku {
    font-size: 12px;
    color: #666;
    margin-top: 4px;
  }
  
  .specs-table {
    width: 100%;
    margin: 20px 0;
  }
  
  .specs-table th {
    text-align: left;
    padding: 8px;
    background: #f5f5f5;
    width: 30%;
  }
  
  .specs-table td {
    padding: 8px;
  }
  
  .features-list {
    list-style: none;
    padding: 0;
  }
  
  .features-list li:before {
    content: "✓ ";
    color: #94be58;
    font-weight: bold;
    margin-right: 8px;
  }
  
  .terms-content {
    line-height: 1.6;
  }
  
  @media screen {
    .quote-document {
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
  }
  
  .autosave-status {
    font-size: 14px;
    padding: 6px 12px;
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  
  .autosave-status-info {
    background: #e0f2fe;
    color: #0369a1;
  }
  
  .autosave-status-success {
    background: #dcfce7;
    color: #166534;
  }
  
  .autosave-status-error {
    background: #fee2e2;
    color: #991b1b;
  }
</style>
