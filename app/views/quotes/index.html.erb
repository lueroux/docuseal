<div class="container mx-auto px-4 py-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-4xl font-bold">Quotes</h1>
    <%= link_to new_quote_wizard_path, class: 'btn btn-primary' do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      New Quote
    <% end %>
  </div>

  <% if @quotes.any? %>
    <div class="card bg-base-100 shadow">
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Reference</th>
              <th>Customer</th>
              <th>Title</th>
              <th>Status</th>
              <th>Total</th>
              <th>Valid Until</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @quotes.each do |quote| %>
              <tr>
                <td class="font-mono"><%= quote.reference_number %></td>
                <td><%= quote.customer&.name || '-' %></td>
                <td><%= quote.title || '-' %></td>
                <td>
                  <span class="badge <%= case quote.status
                    when 'draft' then 'badge-ghost'
                    when 'sent' then 'badge-info'
                    when 'viewed' then 'badge-primary'
                    when 'accepted' then 'badge-success'
                    when 'declined' then 'badge-error'
                    when 'expired' then 'badge-warning'
                    end %>">
                    <%= quote.status.titleize %>
                  </span>
                </td>
                <td class="font-mono">£<%= number_with_precision(quote.total_price, precision: 2) %></td>
                <td><%= quote.valid_until&.strftime('%d/%m/%Y') || '-' %></td>
                <td><%= quote.created_at.strftime('%d/%m/%Y') %></td>
                <td>
                  <div class="flex gap-2">
                    <%= link_to quote_path(quote), class: 'btn btn-sm btn-ghost' do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                    <% end %>
                    <%= link_to edit_quote_path(quote), class: 'btn btn-sm btn-ghost' do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    <% end %>
                    <%= button_to quote_path(quote), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'btn btn-sm btn-ghost text-error' do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-4">
      <%= render 'shared/pagination', pagy: @pagy, items_name: 'quotes' if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto text-base-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p class="text-xl text-base-content/70 mb-4">No quotes yet</p>
      <%= link_to 'Create your first quote', new_quote_wizard_path, class: 'btn btn-primary' %>
    </div>
  <% end %>
</div>
