<%= render 'quote_wizard/layout' do %>
  <h2 class="text-2xl font-bold mb-6">Review Pricing</h2>

  <% if @quote_items.any? %>
    <div class="space-y-4 mb-6">
      <% @quote_items.each do |quote_item| %>
        <div class="card bg-base-100 border border-base-300">
          <div class="card-body p-4">
            <%= form_with model: quote_item, url: update_item_quote_wizard_path(@quote, item_id: quote_item.id),
                method: :patch, data: { turbo_frame: "quote_item_#{quote_item.id}" } do |f| %>
              
              <div class="flex items-center justify-between gap-4" 
                   data-controller="price-calculator" 
                   data-price-calculator-retail-value="<%= quote_item.retail_price %>"
                   data-price-calculator-options-total-value="<%= quote_item.options_total %>"
                   data-price-calculator-quantity-value="<%= quote_item.quantity %>">
                <!-- Product Info -->
                <div class="flex-1">
                  <div class="flex items-center gap-2">
                    <h4 class="font-semibold"><%= quote_item.product.name %></h4>
                    <button type="button"
                            class="btn btn-xs btn-ghost btn-circle"
                            data-controller="product-modal"
                            data-action="click->product-modal#open"
                            data-modal-id="product-detail-modal-<%= quote_item.id %>">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
                        <path fill-rule="evenodd" d="M8 2.5A5.5 5.5 0 1 0 13.5 8 5.5 5.5 0 0 0 8 2.5ZM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0ZM8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" />
                        <path d="M6.75 8a.75.75 0 0 1 .75-.75h2.25a.75.75 0 0 1 0 1.5H7.5A.75.75 0 0 1 6.75 8Z" />
                      </svg>
                    </button>
                  </div>
                  <div class="text-sm text-base-content/70">
                    SKU: <%= quote_item.product.sku %> | Qty: <%= quote_item.quantity %>
                  </div>
                </div>

                <!-- Pricing Grid -->
                <div class="grid grid-cols-5 gap-3 items-end">
                  
                  <div class="form-control">
                    <label class="label label-text text-xs">Cost Price</label>
                    <div class="input input-bordered input-sm bg-base-200 flex items-center">
                      £<%= number_with_precision(quote_item.cost_price, precision: 2) %>
                    </div>
                  </div>

                  <div class="form-control">
                    <label class="label label-text text-xs">Retail Price</label>
                    <div class="input input-bordered input-sm bg-base-200 flex items-center">
                      £<%= number_with_precision(quote_item.retail_price, precision: 2) %>
                    </div>
                  </div>

                  <div class="form-control">
                    <label class="label label-text text-xs">Discount £</label>
                    <div class="input-group input-group-sm">
                      <span>£</span>
                      <input type="number" step="0.01" min="0"
                             value="<%= ((quote_item.retail_price - quote_item.quoted_price) rescue 0).round(2) %>"
                             class="input input-bordered input-sm w-24"
                             data-price-calculator-target="discountAmount"
                             data-action="input->price-calculator#discountAmountChanged">
                    </div>
                  </div>

                  <div class="form-control">
                    <label class="label label-text text-xs">Discount %</label>
                    <%= f.number_field :discount_percentage, min: 0, max: 100, step: 0.1,
                        class: 'input input-bordered input-sm w-20',
                        data: { 
                          price_calculator_target: 'discountPercentage',
                          action: 'input->price-calculator#discountPercentageChanged' 
                        } %>
                  </div>

                  <div class="form-control">
                    <label class="label label-text text-xs">Final Price</label>
                    <div class="input-group input-group-sm">
                      <span>£</span>
                      <%= f.number_field :quoted_price, step: 0.01, 
                          class: 'input input-bordered input-sm w-28',
                          data: { 
                            price_calculator_target: 'quotedPrice',
                            action: 'input->price-calculator#quotedPriceChanged' 
                          } %>
                    </div>
                  </div>
                </div>

                <!-- Line Total -->
                <div class="text-right min-w-[120px]">
                  <div class="text-xs text-base-content/70">Line Total</div>
                  <div class="text-xl font-bold" data-price-calculator-target="lineTotal">
                    £<%= number_with_precision(quote_item.total_with_options, precision: 2, delimiter: ',') %>
                  </div>
                </div>
              </div>

              <!-- Margin Indicator -->
              <% margin = ((quote_item.quoted_price - quote_item.cost_price) / quote_item.cost_price * 100).round(1) rescue 0 %>
              <div class="mt-2 flex items-center gap-2">
                <div class="text-xs text-base-content/70">Margin:</div>
                <div class="badge <%= margin >= 30 ? 'badge-success' : margin >= 15 ? 'badge-warning' : 'badge-error' %>">
                  <%= margin %>%
                </div>
                <% if quote_item.options_total > 0 %>
                  <div class="text-xs text-base-content/70">
                    (includes £<%= number_with_precision(quote_item.options_total, precision: 2) %> in options)
                  </div>
                <% end %>
              </div>

              <!-- Selected Options with Editable Pricing -->
              <% selected_opts = quote_item.quote_item_options.includes(:product_option).where(is_selected: true) %>
              <% if selected_opts.any? %>
                <div class="mt-4 pt-3 border-t border-base-200">
                  <div class="text-sm font-semibold mb-2">Selected Options</div>
                  <div class="grid grid-cols-1 gap-2">
                    <% selected_opts.each do |qio| %>
                      <div class="flex items-center justify-between gap-3 bg-base-200 rounded p-2">
                        <div class="flex-1 min-w-0">
                          <div class="text-sm truncate"><%= qio.product_option.name %></div>
                          <% if qio.product_option.linked_product %>
                            <div class="text-xs text-base-content/60">SKU: <%= qio.product_option.linked_product.sku %></div>
                          <% end %>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                          <span class="text-xs text-base-content/70">Price</span>
                          <%= form_with model: qio, 
                              url: update_option_price_quote_wizard_path(@quote, option_id: qio.id),
                              method: :patch,
                              data: { turbo_frame: "quote_item_#{quote_item.id}" },
                              class: 'flex items-center gap-1' do |of| %>
                            <span>£</span>
                            <%= of.number_field :price, 
                                value: qio.price,
                                step: 0.01, min: 0,
                                class: 'input input-bordered input-xs w-20',
                                data: { action: 'change->price-calculator#submitForm blur->price-calculator#submitForm' } %>
                            <%= of.submit '✓', class: 'btn btn-xs btn-ghost hidden' %>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Pricing Summary -->
    <div class="card bg-base-200">
      <div class="card-body">
        <h3 class="text-lg font-semibold mb-4">Pricing Summary</h3>
        
        <div class="space-y-2">
          <div class="flex justify-between">
            <span>Subtotal:</span>
            <span class="font-mono">£<%= number_with_precision(@quote.calculate_total, precision: 2, delimiter: ',') %></span>
          </div>
          
          <% total_cost = @quote_items.sum { |item| item.cost_price * item.quantity } %>
          <% total_retail = @quote_items.sum { |item| item.retail_price * item.quantity } %>
          <% overall_margin = (((@quote.calculate_total - total_cost) / total_cost) * 100).round(1) rescue 0 %>
          
          <div class="flex justify-between text-sm text-base-content/70">
            <span>Total Cost:</span>
            <span class="font-mono">£<%= number_with_precision(total_cost, precision: 2, delimiter: ',') %></span>
          </div>
          
          <div class="flex justify-between text-sm text-base-content/70">
            <span>Total Retail:</span>
            <span class="font-mono">£<%= number_with_precision(total_retail, precision: 2, delimiter: ',') %></span>
          </div>
          
          <div class="divider my-2"></div>
          
          <div class="flex justify-between items-center">
            <span class="font-semibold">Overall Margin:</span>
            <div class="badge badge-lg <%= overall_margin >= 30 ? 'badge-success' : overall_margin >= 15 ? 'badge-warning' : 'badge-error' %>">
              <%= overall_margin %>%
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quote Total -->
    <div class="mt-6">
      <%= render 'quote_wizard/quote_total', quote: @quote %>
    </div>

    <!-- Payment Structures -->
    <div class="mt-6">
      <%= render 'quote_wizard/payment_structures', quote: @quote, payment_structures: @payment_structures %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-base-200 rounded-lg">
      <p class="text-xl text-base-content/70">No products to price</p>
    </div>
  <% end %>

  <!-- Product Detail Modals -->
  <% @quote_items.each do |quote_item| %>
    <dialog id="product-detail-modal-<%= quote_item.id %>" class="modal">
      <div class="modal-box max-w-4xl">
        <form method="dialog">
          <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
        </form>
        <h3 class="font-bold text-lg mb-4"><%= quote_item.product.name %></h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Product Image -->
          <% if quote_item.product.image_url.present? %>
            <div>
              <%= image_tag quote_item.product.image_url, class: 'w-full h-64 object-contain rounded-lg', alt: quote_item.product.name %>
            </div>
          <% end %>
          
          <!-- Basic Info -->
          <div class="space-y-2">
            <div><span class="font-semibold">SKU:</span> <%= quote_item.product.sku %></div>
            <div><span class="font-semibold">Brand:</span> <%= quote_item.product.brand || 'N/A' %></div>
            <div><span class="font-semibold">Category:</span> <%= quote_item.product.category || 'N/A' %></div>
            <div><span class="font-semibold">Retail Price:</span> <%= number_to_currency(quote_item.product.retail_price) %></div>
          </div>
        </div>

        <!-- Description -->
        <% if quote_item.product.description.present? || quote_item.product.short_description.present? %>
          <div class="mt-4">
            <h4 class="font-semibold mb-2">Description</h4>
            <% if quote_item.product.short_description.present? %>
              <p class="text-sm text-base-content/80"><%= quote_item.product.short_description %></p>
            <% end %>
            <% if quote_item.product.description.present? %>
              <div class="prose prose-sm max-w-none mt-2">
                <%= quote_item.product.description %>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Specifications -->
        <% if quote_item.product.spec_data.present? || quote_item.product.woo_attributes.present? %>
          <div class="mt-4">
            <h4 class="font-semibold mb-2">Specifications</h4>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <% quote_item.product.spec_data.each do |key, value| %>
                <% next if value.blank? %>
                <div class="border-b border-base-200 pb-1">
                  <span class="font-semibold"><%= key.to_s.humanize %>:</span>
                  <span class="ml-2"><%= value %></span>
                </div>
              <% end %>

              <% quote_item.product.woo_attributes.each do |key, value| %>
                <% next if value.blank? %>
                <% next unless quote_item.product.attribute_visible?(key) %>
                <div class="border-b border-base-200 pb-1">
                  <span class="font-semibold"><%= quote_item.product.attribute_label(key) %>:</span>
                  <span class="ml-2">
                    <%= value.is_a?(Array) ? value.join(', ') : value %>
                  </span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button>close</button>
      </form>
    </dialog>
  <% end %>

  <script nonce="<%= content_security_policy_nonce %>" data-turbo-track="reload">
    (function() {
      // Real-time line total updates for each quote item pricing row
      document.querySelectorAll('[data-controller="price-calculator"]').forEach(function(container) {
        const quotedPriceInput = container.querySelector('[data-price-calculator-target="quotedPrice"]');
        const discountPctInput = container.querySelector('[data-price-calculator-target="discountPercentage"]');
        const discountAmtInput = container.querySelector('[data-price-calculator-target="discountAmount"]');
        const lineTotalEl = container.querySelector('[data-price-calculator-target="lineTotal"]');
        const retailEl = container.querySelector('[data-price-calculator-target="retailPrice"]');
        
        if (!quotedPriceInput || !lineTotalEl) return;
        
        const retailPrice = parseFloat(container.dataset.priceCalculatorRetailValue) || 0;
        const optionsTotal = parseFloat(container.dataset.priceCalculatorOptionsTotalValue) || 0;
        const quantity = parseFloat(container.dataset.priceCalculatorQuantityValue) || 1;
        
        let updateTimeout;
        
        function updateLineTotal() {
          const qp = parseFloat(quotedPriceInput.value) || 0;
          const total = (qp + optionsTotal) * quantity;
          lineTotalEl.textContent = '£' + total.toLocaleString('en-GB', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        
        function submitForm() {
          clearTimeout(updateTimeout);
          updateTimeout = setTimeout(function() {
            const form = quotedPriceInput.closest('form');
            if (form && form.requestSubmit) form.requestSubmit();
          }, 500);
        }
        
        // Sync discount % / amount with quoted price
        function syncFromQuotedPrice() {
          const qp = parseFloat(quotedPriceInput.value) || 0;
          if (retailPrice > 0) {
            const amt = retailPrice - qp;
            const pct = (amt / retailPrice) * 100;
            if (discountAmtInput) discountAmtInput.value = Math.max(0, amt).toFixed(2);
            if (discountPctInput) discountPctInput.value = Math.max(0, pct).toFixed(2);
          }
          updateLineTotal();
        }
        
        function syncFromDiscountPct() {
          const pct = parseFloat(discountPctInput.value) || 0;
          if (retailPrice > 0) {
            const amt = (retailPrice * pct) / 100;
            const qp = retailPrice - amt;
            quotedPriceInput.value = Math.max(0, qp).toFixed(2);
            if (discountAmtInput) discountAmtInput.value = Math.max(0, amt).toFixed(2);
          }
          updateLineTotal();
        }
        
        function syncFromDiscountAmt() {
          const amt = parseFloat(discountAmtInput.value) || 0;
          const qp = Math.max(0, retailPrice - amt);
          quotedPriceInput.value = qp.toFixed(2);
          if (retailPrice > 0 && discountPctInput) {
            discountPctInput.value = ((amt / retailPrice) * 100).toFixed(2);
          }
          updateLineTotal();
        }
        
        quotedPriceInput.addEventListener('input', function() {
          syncFromQuotedPrice();
          submitForm();
        });
        
        if (discountPctInput) {
          discountPctInput.addEventListener('input', function() {
            syncFromDiscountPct();
            submitForm();
          });
        }
        
        if (discountAmtInput) {
          discountAmtInput.addEventListener('input', function() {
            syncFromDiscountAmt();
            submitForm();
          });
        }
        
        // Initial update
        updateLineTotal();
      });
    })();
  </script>
<% end %>
