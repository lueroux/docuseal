<div id="attachment_<%= attachment.id %>" class="flex items-center gap-4 p-4 bg-base-200 rounded-lg">
  <div class="flex-shrink-0">
    <% if attachment.image? %>
      <%= image_tag rails_blob_url(attachment.file), class: 'w-12 h-12 object-cover rounded' %>
    <% elsif attachment.pdf? %>
      <div class="w-12 h-12 flex items-center justify-center bg-error/10 text-error rounded">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
      </div>
    <% else %>
      <div class="w-12 h-12 flex items-center justify-center bg-base-300 rounded">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
    <% end %>
  </div>

  <div class="flex-grow min-w-0">
    <div class="font-semibold truncate"><%= attachment.name %></div>
    <% if attachment.description.present? %>
      <div class="text-sm text-base-content/70 truncate"><%= attachment.description %></div>
    <% end %>
    <div class="text-xs text-base-content/50 mt-0.5">
      <%= attachment.file.filename %>
      &middot;
      <%= number_to_human_size(attachment.file.byte_size) %>
    </div>
  </div>

  <div class="flex-shrink-0 flex items-center gap-2">
    <%= link_to rails_blob_url(attachment.file, disposition: 'inline'),
                class: 'btn btn-ghost btn-sm', target: '_blank', rel: 'noopener',
                title: 'Preview' do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
      </svg>
    <% end %>
    <%= button_to remove_attachment_quote_wizard_path(@quote, attachment_id: attachment.id),
                  method: :delete,
                  class: 'btn btn-ghost btn-sm text-error',
                  title: 'Remove',
                  data: { turbo_confirm: 'Remove this attachment?' } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
    <% end %>
  </div>
</div>
