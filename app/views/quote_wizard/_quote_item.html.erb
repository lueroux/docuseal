<div id="quote_item_<%= quote_item.id %>" class="card bg-base-100 border border-base-300">
  <div class="card-body p-4">
    <div class="flex items-start justify-between gap-4">
      <!-- Product Info -->
      <div class="flex-1">
        <h4 class="font-semibold text-lg"><%= quote_item.product.name %></h4>
        <div class="text-sm text-base-content/70 space-y-1">
          <p><strong>SKU:</strong> <%= quote_item.product.sku %></p>
          <% if quote_item.product.brand.present? %>
            <p><strong>Brand:</strong> <%= quote_item.product.brand %></p>
          <% end %>
        </div>
      </div>

      <!-- Quantity & Price Controls -->
      <div class="flex items-center gap-4">
        <%= form_with model: quote_item, url: update_item_quote_wizard_path(@quote, item_id: quote_item.id),
            method: :patch, data: { turbo_frame: "quote_item_#{quote_item.id}" }, 
            class: 'flex items-center gap-2' do |f| %>
          
          <div class="form-control">
            <label class="label label-text text-xs">Qty</label>
            <%= f.number_field :quantity, min: 1, value: quote_item.quantity,
                class: 'input input-bordered input-sm w-20',
                data: { action: 'change->form#submit' } %>
          </div>

          <div class="form-control">
            <label class="label label-text text-xs">Price (£)</label>
            <%= f.number_field :quoted_price, step: 0.01, value: quote_item.quoted_price,
                class: 'input input-bordered input-sm w-28',
                data: { action: 'change->form#submit' } %>
          </div>

          <div class="form-control">
            <label class="label label-text text-xs">Discount (%)</label>
            <%= f.number_field :discount_percentage, min: 0, max: 100, step: 0.1, 
                value: quote_item.discount_percentage || 0,
                class: 'input input-bordered input-sm w-24',
                data: { action: 'change->form#submit' } %>
          </div>
        <% end %>

        <!-- Line Total -->
        <div class="text-right">
          <div class="text-xs text-base-content/70">Total</div>
          <div class="text-lg font-bold">
            £<%= number_with_precision(quote_item.line_total, precision: 2, delimiter: ',') %>
          </div>
        </div>

        <!-- Remove Button -->
        <%= button_to remove_item_quote_wizard_path(@quote, item_id: quote_item.id),
            method: :delete,
            data: { turbo_confirm: 'Remove this product?', turbo_frame: 'quote_items_list' },
            class: 'btn btn-ghost btn-sm btn-square text-error' do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        <% end %>
      </div>
    </div>

    <!-- Options (if any) -->
    <% if quote_item.quote_item_options.any? %>
      <div class="mt-3 pt-3 border-t border-base-300">
        <div class="text-sm font-semibold mb-2">Selected Options:</div>
        <div class="space-y-1">
          <% quote_item.quote_item_options.where(is_selected: true).each do |option| %>
            <div class="flex justify-between text-sm">
              <span><%= option.name %></span>
              <span class="font-mono">+£<%= number_with_precision(option.price, precision: 2) %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Notes -->
    <% if quote_item.notes.present? %>
      <div class="mt-3 pt-3 border-t border-base-300">
        <div class="text-sm text-base-content/70">
          <strong>Notes:</strong> <%= quote_item.notes %>
        </div>
      </div>
    <% end %>
  </div>
</div>
