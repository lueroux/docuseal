<div class="flex justify-center">
  <div class="card bg-base-200 w-full max-w-md shadow-lg">
    <div class="card-body">
      <h2 class="card-title text-2xl mb-2">Sign in to your portal</h2>
      <p class="text-sm opacity-70 mb-6">Enter your email address and we'll send you a secure sign-in link.</p>

      <%= form_with url: portal_login_path, method: :post, class: 'space-y-4' do |f| %>
        <div class="form-control">
          <%= f.label :email, 'Email address', class: 'label label-text font-medium' %>
          <%= f.email_field :email, required: true, autofocus: true,
                class: 'input input-bordered w-full',
                placeholder: 'you@example.com' %>
        </div>
        <%= f.submit 'Send sign-in link', class: 'btn btn-primary w-full mt-2' %>
      <% end %>
    </div>
  </div>
</div>
