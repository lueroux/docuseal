<%= form_with model: [product, product.product_documents.build], url: product_product_documents_path(product), 
    local: true, id: 'document_upload_form' do |f| %>
  <div class="space-y-3">
    <div class="form-control">
      <%= f.label :name, 'Document Name', class: 'label' %>
      <%= f.text_field :name, class: 'input input-bordered', required: true, placeholder: 'e.g., Product Manual' %>
    </div>
    
    <div class="form-control">
      <%= f.label :file, 'File (PDF or Image)', class: 'label' %>
      <%= f.file_field :file, class: 'file-input file-input-bordered', 
          accept: '.pdf,.png,.jpg,.jpeg,.gif,.webp', required: true %>
      <label class="label">
        <span class="label-text-alt text-base-content/60">Accepted: PDF, PNG, JPG, GIF, WebP</span>
      </label>
    </div>

    <div class="form-control">
      <%= f.label :sort_order, 'Sort Order', class: 'label' %>
      <%= f.number_field :sort_order, class: 'input input-bordered', value: product.product_documents.count %>
    </div>

    <% if defined?(errors) && errors.any? %>
      <div class="alert alert-error">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span><%= errors.full_messages.to_sentence %></span>
      </div>
    <% end %>

    <div class="flex justify-end">
      <%= f.submit 'Upload Document', class: 'btn btn-primary' %>
    </div>
  </div>
<% end %>
