<%= form_with model: @product do |f| %>
  <% if @product.errors.any? %>
    <div class="alert alert-error mb-4">
      <h3 class="font-bold"><%= pluralize(@product.errors.count, 'error') %> prohibited this product from being saved:</h3>
      <ul>
        <% @product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @product.persisted? %>
    <div class="card bg-base-100 border border-base-300 mb-4">
      <div class="card-body p-4">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-semibold">WooCommerce Sync</h3>
            <p class="text-sm text-base-content/70">
              <% if @product.synced? %>
                Last synced <%= time_ago_in_words(@product.synced_at) %> ago
                <% if @product.woocommerce_product_id.present? %>
                  &middot; WooCommerce ID: <code class="font-mono"><%= @product.woocommerce_product_id %></code>
                <% end %>
              <% else %>
                Not yet synced from WooCommerce
              <% end %>
            </p>
          </div>
          <div class="flex gap-2">
            <%= link_to 'Sync Now', sync_product_path(@product), method: :post, class: 'btn btn-secondary btn-sm', data: { turbo_method: :post, turbo_confirm: 'Fetch latest data from WooCommerce?' } %>
          </div>
        </div>
        <% if @product.manual_edit_flags.present? && @product.manual_edit_flags.any? %>
          <div class="mt-3 text-sm">
            <span class="text-base-content/70">Manually edited fields:</span>
            <div class="flex flex-wrap gap-1 mt-1">
              <% @product.manual_edit_flags.keys.each do |field| %>
                <span class="badge badge-primary badge-sm"><%= field.to_s.humanize %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <ibcos-lookup class="form-control">
      <%= f.label :sku, class: 'label' %>
      <div class="flex gap-2">
        <%= f.text_field :sku, class: 'input input-bordered flex-1', required: true, 
            id: 'product_sku', data: { sku: true } %>
        <button type="button" class="btn btn-secondary" data-button>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Search IBCOS
        </button>
      </div>
      <div class="text-sm mt-1" data-status></div>
    </ibcos-lookup>

    <div class="form-control">
      <%= f.label :name, class: 'label' %>
      <%= f.text_field :name, class: 'input input-bordered', required: true, id: 'product_name' %>
      <% if @product.manually_edited?('name') %>
        <span class="text-xs text-primary mt-1">Manually edited — sync will not overwrite this field</span>
      <% end %>
    </div>

    <div class="form-control">
      <%= f.label :brand, class: 'label' %>
      <%= f.text_field :brand, class: 'input input-bordered', id: 'product_brand' %>
      <% if @product.manually_edited?('brand') %>
        <span class="text-xs text-primary mt-1">Manually edited — sync will not overwrite this field</span>
      <% end %>
    </div>

    <div class="form-control">
      <%= f.label :category, class: 'label' %>
      <%= f.text_field :category, class: 'input input-bordered', id: 'product_category' %>
      <% if @product.manually_edited?('category') %>
        <span class="text-xs text-primary mt-1">Manually edited — sync will not overwrite this field</span>
      <% end %>
    </div>

    <div class="form-control">
      <%= f.label :retail_price, class: 'label' %>
      <%= f.number_field :retail_price, step: 0.01, class: 'input input-bordered', required: true, id: 'product_retail_price' %>
      <% if @product.manually_edited?('retail_price') %>
        <span class="text-xs text-primary mt-1">Manually edited — sync will not overwrite this field</span>
      <% end %>
    </div>

    <div class="form-control">
      <%= f.label :cost_price, class: 'label' %>
      <%= f.number_field :cost_price, step: 0.01, class: 'input input-bordered', id: 'product_cost_price' %>
    </div>

    <div class="form-control">
      <%= f.label :markup_percentage, class: 'label' %>
      <%= f.number_field :markup_percentage, step: 0.01, class: 'input input-bordered' %>
    </div>

    <div class="form-control">
      <%= f.label :woocommerce_product_id, class: 'label' %>
      <%= f.number_field :woocommerce_product_id, class: 'input input-bordered', placeholder: 'WooCommerce product ID', id: 'product_woocommerce_product_id' %>
    </div>

    <div class="form-control">
      <%= f.label :image_url, class: 'label' %>
      <%= f.url_field :image_url, class: 'input input-bordered', placeholder: 'https://...', id: 'product_image_url' %>
      <% if @product.manually_edited?('image_url') %>
        <span class="text-xs text-primary mt-1">Manually edited — sync will not overwrite this field</span>
      <% end %>
    </div>

    <div class="form-control">
      <%= f.label :available, class: 'label' %>
      <%= f.check_box :available, class: 'checkbox checkbox-primary' %>
    </div>
  </div>

  <div class="form-control mt-4">
    <%= f.label :description, class: 'label' %>
    <%= f.text_area :description, rows: 3, class: 'textarea textarea-bordered', id: 'product_description' %>
    <% if @product.manually_edited?('description') %>
      <span class="text-xs text-primary mt-1">Manually edited — sync will not overwrite this field</span>
    <% end %>
  </div>

  <% if @product.image_url.present? %>
    <div class="mt-4">
      <label class="label">Image Preview</label>
      <%= image_tag @product.image_url, class: 'w-48 h-48 object-contain rounded-lg border border-base-300', alt: @product.name %>
    </div>
  <% end %>

  <div class="flex justify-end gap-2 mt-6">
    <%= f.submit 'Save Product', class: 'btn btn-primary' %>
    <%= link_to 'Cancel', @product.persisted? ? @product : products_path, class: 'btn btn-ghost' %>
  </div>
<% end %>
