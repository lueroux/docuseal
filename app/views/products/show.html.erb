<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold"><%= @product.display_name %></h1>
  <div class="flex gap-2">
    <%= link_to 'Sync', sync_product_path(@product), method: :post, class: 'btn btn-secondary', data: { turbo_method: :post, turbo_confirm: 'Sync with WooCommerce?' } %>
    <%= link_to 'Edit', edit_product_path(@product), class: 'btn btn-primary' %>
    <%= button_to 'Delete', @product, method: :delete,
        class: 'btn btn-error btn-ghost',
        data: { turbo_confirm: 'Are you sure?' } %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- Product Image and Basic Info -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <div class="flex gap-6">
          <% if @product.image_url.present? %>
            <div class="flex-shrink-0">
              <%= image_tag @product.image_url, class: 'w-48 h-48 object-contain rounded-lg', alt: @product.name %>
            </div>
          <% end %>
          <div class="flex-1">
            <h2 class="card-title text-2xl"><%= @product.name %></h2>
            <div class="mt-2 text-sm text-base-content/70">
              <div class="grid grid-cols-2 gap-2">
                <div><span class="font-semibold">SKU:</span> <%= @product.sku %></div>
                <div><span class="font-semibold">Brand:</span> <%= @product.brand || 'N/A' %></div>
                <div><span class="font-semibold">Category:</span> <%= @product.category || 'N/A' %></div>
                <div>
                  <span class="font-semibold">Available:</span>
                  <%= content_tag :span, @product.available? ? 'Yes' : 'No',
                      class: "badge #{@product.available? ? 'badge-success' : 'badge-error'} ml-1" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Description -->
    <% if @product.description.present? || @product.short_description.present? %>
      <div class="card bg-base-100 shadow">
        <div class="card-body">
          <h2 class="card-title">Description</h2>
          <% if @product.short_description.present? %>
            <p class="text-base-content/80 mt-2"><%= @product.short_description %></p>
          <% end %>
          <% if @product.description.present? %>
            <div class="prose prose-sm max-w-none mt-4">
              <%= @product.description %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Product Specs -->
    <% if @product.spec_data.present? || @product.woo_attributes.present? %>
      <div class="card bg-base-100 shadow">
        <div class="card-body">
          <h2 class="card-title">Specifications</h2>
          <div class="mt-4 space-y-2">
            <% @product.spec_data.each do |key, value| %>
              <% next if value.blank? %>
              <div class="flex justify-between border-b border-base-200 pb-2">
                <span class="font-semibold"><%= key.humanize %>:</span>
                <span class="text-base-content/80"><%= value %></span>
              </div>
            <% end %>

            <% @product.woo_attributes.each do |key, value| %>
              <% next if value.blank? %>
              <% visibility = @product.attribute_visibility.dig(key) %>
              <% next if visibility && !visibility['visible_on_detail_page'] %>
              <div class="flex justify-between border-b border-base-200 pb-2">
                <span class="font-semibold"><%= visibility&.dig('label') || key.humanize %>:</span>
                <span class="text-base-content/80">
                  <%= value.is_a?(Array) ? value.join(', ') : value %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Pricing -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title">Pricing</h2>
        <div class="grid grid-cols-2 gap-4 mt-4">
          <div>
            <span class="font-semibold">Cost Price:</span>
            <span class="ml-2"><%= number_to_currency(@product.cost_price) if @product.cost_price %></span>
          </div>
          <div>
            <span class="font-semibold">Markup:</span>
            <span class="ml-2"><%= "#{@product.markup_percentage}%" if @product.markup_percentage %></span>
          </div>
          <div class="col-span-2">
            <span class="font-semibold text-lg">Retail Price:</span>
            <span class="ml-2 text-lg"><%= number_to_currency(@product.retail_price) %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-6">
    <!-- Quick Actions -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title">Quick Actions</h2>
        <div class="space-y-2 mt-4">
          <div class="text-sm">
            <span class="font-semibold">WooCommerce ID:</span>
            <span class="ml-2"><%= @product.woocommerce_product_id || 'N/A' %></span>
          </div>
          <div class="text-sm">
            <span class="font-semibold">Last Sync:</span>
            <span class="ml-2">
              <% if @product.synced? %>
                <%= time_ago_in_words(@product.synced_at) %> ago
              <% else %>
                <span class="text-base-content/50">Not synced</span>
              <% end %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Product Options -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title">Product Options</h2>
        <div class="mt-4">
          <% if @product.product_options.any? %>
            <ul class="menu bg-base-200 rounded-box">
              <% @product.product_options.ordered.each do |option| %>
                <li>
                  <div class="flex justify-between">
                    <span><%= option.name %></span>
                    <span><%= number_to_currency(option.price) %></span>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm opacity-70">No options configured</p>
          <% end %>
        </div>
        <%= link_to 'Manage Options', product_product_options_path(@product), class: 'btn btn-sm btn-primary mt-4' %>
      </div>
    </div>

    <!-- Compatibility Rules -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title">Compatibility Rules</h2>
        <div class="mt-4">
          <% if @product.product_compatibility_rules.any? %>
            <ul class="menu bg-base-200 rounded-box">
              <% @product.product_compatibility_rules.each do |rule| %>
                <li>
                  <div>
                    <span class="badge badge-<%= rule.rule_type == 'requires' ? 'warning' : rule.rule_type == 'excludes' ? 'error' : 'info' %>">
                      <%= rule.rule_type %>
                    </span>
                    <span class="ml-2"><%= rule.condition_value %></span>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm opacity-70">No rules configured</p>
          <% end %>
        </div>
        <%= link_to 'Manage Rules', product_product_compatibility_rules_path(@product), class: 'btn btn-sm btn-primary mt-4' %>
      </div>
    </div>
  </div>
</div>
