<h1 class="text-2xl font-bold mb-6">Edit Product</h1>

<div class="card bg-base-100 shadow p-6">
  <%= render 'form' %>
</div>

<div class="card bg-base-100 shadow p-6 mt-6 border-2 border-primary/20">
  <h2 class="text-xl font-extrabold mb-2 flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
    </svg>
    Add-ons &amp; Options
  </h2>
  <p class="text-sm text-base-content/70 mb-4">Options appear as selectable add-ons in the quote wizard and on product detail pages. Link a product to pull its retail price and SKU automatically.</p>
  
  <% if @product.product_options.any? %>
  <div class="overflow-x-auto mb-4">
    <table class="table table-sm">
      <thead>
        <tr class="bg-base-200">
          <th class="font-bold">Name</th>
          <th class="font-bold">Description</th>
          <th class="font-bold">Price</th>
          <th class="font-bold">Linked Product</th>
          <th class="font-bold">Required</th>
          <th class="font-bold">Cust. Choice</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="product_options_list">
        <% @product.product_options.order(:sort_order).each do |option| %>
          <tr id="option_<%= option.id %>" class="hover:bg-base-100">
            <td class="font-semibold"><%= option.name %></td>
            <td class="text-sm text-base-content/70"><%= option.description.presence || '<span class="text-base-content/30 italic">—</span>'.html_safe %></td>
            <td class="font-mono font-semibold"><%= option.price > 0 ? number_to_currency(option.price) : '<span class="text-success font-bold">Free</span>'.html_safe %></td>
            <td><%= option.linked_product ? "<span class='font-medium'>#{option.linked_product.name}</span> <span class='text-xs text-base-content/50'>(#{option.linked_product.sku})</span>".html_safe : '<span class="text-base-content/30 italic">—</span>'.html_safe %></td>
            <td><%= option.is_required ? '<span class="badge badge-warning badge-sm font-bold">Required</span>'.html_safe : '<span class="badge badge-ghost badge-sm">Optional</span>'.html_safe %></td>
            <td><%= option.customer_choice ? '<span class="badge badge-info badge-sm font-bold">Yes</span>'.html_safe : '<span class="badge badge-ghost badge-sm">No</span>'.html_safe %></td>
            <td>
              <%= button_to 'Remove', product_product_option_path(@product, option), method: :delete, class: 'btn btn-xs btn-error btn-outline', form: { data: { turbo_confirm: 'Remove this option?' } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% else %>
    <div class="bg-base-200 rounded-lg p-6 text-center mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto text-base-content/30 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
      </svg>
      <p class="text-base-content/50 font-medium">No options yet</p>
      <p class="text-sm text-base-content/40">Use the form below to add your first add-on or option.</p>
    </div>
  <% end %>

  <div class="mt-4 p-4 bg-base-200 rounded-lg">
    <h3 class="text-lg font-semibold mb-3">Add Option</h3>
    <%= form_with model: [@product, ProductOption.new], local: true, class: 'space-y-3' do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="form-control">
          <%= f.label :name, class: 'label' %>
          <%= f.text_field :name, class: 'input input-bordered input-sm', placeholder: 'e.g. Cutting Deck', required: true %>
        </div>
        <div class="form-control">
          <%= f.label :description, class: 'label' %>
          <%= f.text_field :description, class: 'input input-bordered input-sm', placeholder: 'Optional description' %>
        </div>
        <div class="form-control">
          <%= f.label :price, 'Price (£)', class: 'label' %>
          <%= f.number_field :price, class: 'input input-bordered input-sm', step: '0.01', placeholder: '0.00' %>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="form-control">
          <%= f.label :linked_product_id, 'Linked Product', class: 'label' %>
          <%= f.collection_select :linked_product_id, Product.available.order(:name), :id, :name, { prompt: 'None' }, class: 'select select-bordered select-sm' %>
        </div>
        <div class="form-control">
          <%= f.label :sort_order, 'Sort Order', class: 'label' %>
          <%= f.number_field :sort_order, class: 'input input-bordered input-sm', value: (@product.product_options.maximum(:sort_order) || 0) + 1 %>
        </div>
        <div class="form-control">
          <label class="label cursor-pointer">
            <span class="label-text">Required</span>
            <%= f.check_box :is_required, class: 'checkbox checkbox-sm checkbox-warning' %>
          </label>
          <label class="label cursor-pointer">
            <span class="label-text">Customer Choice</span>
            <%= f.check_box :customer_choice, class: 'checkbox checkbox-sm checkbox-info' %>
          </label>
        </div>
      </div>
      <div>
        <%= f.submit 'Add Option', class: 'btn btn-sm btn-primary' %>
      </div>
    <% end %>
  </div>
</div>

<div class="card bg-base-100 shadow p-6 mt-6 border-2 border-primary/20">
  <h2 class="text-xl font-extrabold mb-2 flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    Product Documents
  </h2>
  <p class="text-sm text-base-content/70 mb-4">Upload PDFs and images (manuals, spec sheets, brochures) to attach to this product. These will be available in the quote wizard.</p>

  <div id="product_documents_list" class="space-y-2 mb-4">
    <% if @product.product_documents.any? %>
      <% @product.product_documents.ordered.each do |document| %>
        <%= render 'product_documents/document_card', document: document, product: @product %>
      <% end %>
    <% else %>
      <div id="no_documents_notice" class="text-sm text-base-content/50 italic">No documents yet. Use the form below to upload files.</div>
    <% end %>
  </div>

  <div class="mt-4 p-4 bg-base-200 rounded-lg">
    <h3 class="text-lg font-semibold mb-3">Upload Document</h3>
    <%= render 'product_documents/upload_form', product: @product %>
  </div>
</div>
