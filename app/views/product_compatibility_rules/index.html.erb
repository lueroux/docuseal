<% content_for :html_title, "Compatibility Rules · #{@product.display_name}" %>

<div class="mb-6">
  <%= link_to product_path(@product), class: "btn btn-sm btn-ghost" do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
    </svg>
    Back to Product
  <% end %>
</div>

<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <h2 class="card-title">Compatibility Rules for <%= @product.display_name %></h2>

    <% if @product_compatibility_rules.any? %>
      <div class="overflow-x-auto mt-4">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th>Rule Type</th>
              <th>Condition</th>
              <th>Result Action</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @product_compatibility_rules.each do |rule| %>
              <tr>
                <td><%= rule.rule_type %></td>
                <td><%= rule.condition %></td>
                <td><%= rule.result_action %></td>
                <td>
                  <%= button_to 'Remove', product_product_compatibility_rule_path(@product, rule), method: :delete,
                                class: "btn btn-xs btn-error",
                                data: { turbo_confirm: "Are you sure you want to remove this rule?" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="alert alert-info mt-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>No compatibility rules yet. Add the first rule below.</span>
      </div>
    <% end %>

    <div class="divider"></div>

    <h3 class="font-bold text-lg">Add New Rule</h3>
    <%= form_with model: [@product, @product.product_compatibility_rules.build], local: true do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
        <div class="form-control">
          <label class="label"><span class="label-text">Rule Type</span></label>
          <%= f.select :rule_type, %w[exclusion requirement], {}, class: "select select-bordered", required: true %>
        </div>

        <div class="form-control">
          <label class="label"><span class="label-text">Condition</span></label>
          <%= f.text_field :condition, class: "input input-bordered", required: true,
                           placeholder: "e.g., SKU:ABC123" %>
        </div>

        <div class="form-control">
          <label class="label"><span class="label-text">Result Action</span></label>
          <%= f.select :result_action, %w[hide disable show], {}, class: "select select-bordered", required: true %>
        </div>
      </div>

      <div class="form-control mt-4">
        <label class="label"><span class="label-text">Description</span></label>
        <%= f.text_area :description, class: "textarea textarea-bordered", rows: 3 %>
      </div>

      <div class="mt-4">
        <%= f.submit "Add Rule", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
