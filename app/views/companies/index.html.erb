<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Companies</h1>
  <%= link_to 'New Company', new_company_path, class: 'btn btn-primary btn-sm' %>
</div>

<% if @companies.empty? %>
  <div class="alert">No companies yet. <%= link_to 'Add the first one', new_company_path %>.</div>
<% else %>
  <div class="overflow-x-auto">
    <table class="table table-zebra w-full">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Customers</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @companies.each do |company| %>
          <tr>
            <td><%= link_to company.name, company_path(company), class: 'font-medium link link-hover' %></td>
            <td><%= company.email %></td>
            <td><%= company.phone %></td>
            <td><%= company.customers.count %></td>
            <td class="text-right">
              <%= link_to 'Edit', edit_company_path(company), class: 'btn btn-xs btn-ghost' %>
              <%= button_to 'Delete', company_path(company), method: :delete,
                    data: { confirm: 'Delete this company?' },
                    class: 'btn btn-xs btn-ghost text-error' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
