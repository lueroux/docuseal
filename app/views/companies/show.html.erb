<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold"><%= @company.name %></h1>
    <p class="opacity-60 text-sm mt-1">
      <%= @company.email %>
      <% if @company.phone.present? %>· <%= @company.phone %><% end %>
    </p>
  </div>
  <div class="flex gap-2">
    <%= link_to 'Edit', edit_company_path(@company), class: 'btn btn-sm btn-ghost' %>
    <%= button_to 'Delete', company_path(@company), method: :delete,
          data: { confirm: 'Delete this company?' },
          class: 'btn btn-sm btn-error btn-outline' %>
  </div>
</div>

<% if @company.notes.present? %>
  <div class="prose mb-6"><p><%= @company.notes %></p></div>
<% end %>

<div class="flex items-center justify-between mb-3">
  <h2 class="text-lg font-semibold">Customers</h2>
  <%= link_to 'New Customer', new_customer_path(company_id: @company.id), class: 'btn btn-sm btn-primary' %>
</div>

<% if @customers.empty? %>
  <div class="alert">No customers linked to this company yet.</div>
<% else %>
  <div class="overflow-x-auto">
    <table class="table w-full">
      <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th></th></tr></thead>
      <tbody>
        <% @customers.each do |customer| %>
          <tr>
            <td><%= link_to customer.name, customer_path(customer), class: 'link link-hover font-medium' %></td>
            <td><%= customer.email %></td>
            <td><%= customer.phone %></td>
            <td class="text-right">
              <%= link_to 'Edit', edit_customer_path(customer), class: 'btn btn-xs btn-ghost' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
