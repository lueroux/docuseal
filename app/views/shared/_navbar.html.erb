<%= render 'shared/navbar_warning' %>
<div class="navbar bg-base-100 shadow-sm mb-4 px-4 md:px-6">
  <div class="navbar-start">
    <a href="<%= root_path %>" class="text-xl font-bold flex items-center gap-2">
      <%= render 'shared/title' %>
    </a>
  </div>
  <% if signed_in? %>
    <div class="navbar-center hidden lg:flex">
      <div class="flex items-center gap-1">
        <%= render 'shared/navbar_buttons' %>
        <%= link_to 'Quotes', quotes_path, class: 'btn btn-ghost btn-sm' %>
        <%= link_to 'Products', products_path, class: 'btn btn-ghost btn-sm' %>
        <%= link_to 'Companies', companies_path, class: 'btn btn-ghost btn-sm' %>
        <%= link_to 'Customers', customers_path, class: 'btn btn-ghost btn-sm' %>
        <%= link_to t('settings'), settings_profile_index_path, class: 'btn btn-ghost btn-sm', id: 'account_settings_button' %>
      </div>
    </div>
    <div class="navbar-end flex items-center gap-2">
      <!-- Mobile menu -->
      <div class="dropdown dropdown-end lg:hidden">
        <label tabindex="0" class="btn btn-ghost btn-circle">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
        <ul tabindex="0" class="dropdown-content menu menu-sm p-2 mt-3 shadow bg-base-100 rounded-box w-52 z-20">
          <li><%= link_to 'Quotes', quotes_path %></li>
          <li><%= link_to 'Products', products_path %></li>
          <li><%= link_to 'Companies', companies_path %></li>
          <li><%= link_to 'Customers', customers_path %></li>
          <li><%= link_to t('settings'), settings_profile_index_path %></li>
        </ul>
      </div>
      <%= link_to 'New Quote', new_quote_wizard_path, class: 'btn btn-sm btn-primary' %>
      <div class="dropdown dropdown-end">
        <label tabindex="0" class="btn btn-ghost btn-circle avatar placeholder">
          <span class="bg-primary text-primary-content rounded-full w-9">
            <span class="text-sm font-semibold"><%= current_user.initials %></span>
          </span>
        </label>
        <ul tabindex="0" class="dropdown-content menu menu-sm p-2 mt-3 shadow bg-base-100 rounded-box w-52 z-20">
          <li>
            <%= link_to settings_profile_index_path do %>
              <%= svg_icon('adjustments', class: 'w-4 h-4') %>
              <%= t('profile') %>
            <% end %>
          </li>
          <% if can?(:read, EncryptedConfig.new(key: EncryptedConfig::ESIGN_CERTS_KEY, account: current_account)) %>
            <li>
              <%= link_to settings_esign_path do %>
                <%= svg_icon('zoom_check', class: 'w-4 h-4') %>
                <span class="whitespace-nowrap"><%= t('verify_pdf') %></span>
              <% end %>
            </li>
          <% end %>
          <% if Docuseal.multitenant? || current_user.role == 'superadmin' %>
            <li>
              <%= link_to Docuseal::CHATGPT_URL, target: 'blank' do %>
                <%= svg_icon('sparkles', class: 'w-4 h-4') %>
                <span class="whitespace-nowrap"><%= t('ask_ai') %></span>
              <% end %>
            </li>
          <% end %>
          <% if can?(:manage, EncryptedConfig) %>
            <li>
              <%= form_for '', url: testing_account_path, method: current_account.testing? ? :delete : :post do |f| %>
                <label class="flex items-center gap-2 cursor-pointer py-1">
                  <submit-form data-on="change" class="flex">
                    <%= f.check_box :testing_toggle, class: 'toggle toggle-sm', checked: current_account.testing? %>
                  </submit-form>
                  <span class="whitespace-nowrap text-sm"><%= t('test_mode') %></span>
                </label>
              <% end %>
            </li>
          <% end %>
          <li>
            <%= button_to destroy_user_session_path, method: :delete, data: { turbo: false }, class: 'flex items-center gap-2 w-full' do %>
              <%= svg_icon('logout', class: 'w-4 h-4') %>
              <span class="whitespace-nowrap"><%= t('sign_out') %></span>
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  <% else %>
    <div class="flex space-x-2">
      <% if request.path != new_user_session_path && request.path != setup_index_path %>
        <%= link_to new_user_session_path({ lang: params[:lang] }.compact_blank), class: 'font-medium text-lg' do %>
          <span class="flex items-center justify-center space-x-1">
            <%= svg_icon('login', class: 'w-6 h-6') %>
            <span><%= t('sign_in') %></span>
          </span>
        <% end %>
      <% end %>
      <% if Docuseal.multitenant? && !request.path.in?([registration_path, new_registration_path]) %>
        <%= link_to registration_path({ lang: params[:lang] }.compact_blank), class: 'btn btn-neutral btn-sm btn-outline' do %>
          <span class="flex items-center justify-center space-x-1">
            <span class="hidden sm:block capitalize"><%= t('create_free_account') %></span>
            <span class="md:hidden"><%= t('sign_up') %></span>
          </span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
