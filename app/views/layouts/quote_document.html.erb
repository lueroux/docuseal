<!DOCTYPE html>
<html>
<head>
  <title>Quote <%= @quote.reference_number %> - Buxtons Quote Tool</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: #ececec;
      padding: 20px;
    }
    
    .print-button {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 12px 24px;
      background: #94be58;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
      z-index: 1000;
    }
    
    .print-button:hover {
      background: #6f8c46;
    }
    
    @media print {
      body {
        background: white;
        padding: 0;
      }
      
      .print-button {
        display: none;
      }
    }
  </style>
</head>

<body>
  <button class="print-button no-print" id="printButton">Print / Save as PDF</button>
  <%= yield %>
  
  <script nonce="<%= content_security_policy_nonce %>">
    document.getElementById('printButton').addEventListener('click', function() {
      window.print();
    });
  </script>
</body>
</html>
