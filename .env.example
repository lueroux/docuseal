# Rails
RAILS_ENV=production
SECRET_KEY_BASE=                        # rails secret
HOST=https://your-app.up.railway.app    # public URL (no trailing slash)
FORCE_SSL=true

# Database — auto-injected by Railway PostgreSQL plugin
DATABASE_URL=

# Redis — auto-injected by Railway Redis plugin
REDIS_URL=

# Email (required for quote/customer notifications)
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=quotes@buxtons.co.uk
SMTP_DOMAIN=buxtons.co.uk
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# Active Storage — use "local" with a Railway volume, or "amazon" for S3
ACTIVE_STORAGE_SERVICE=local

# S3 (only if ACTIVE_STORAGE_SERVICE=amazon)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
AWS_BUCKET=

# IBCOS Gold (configure via /settings/ibcos or env vars)
IBCOS_URL=
IBCOS_USERNAME=
IBCOS_PASSWORD=
IBCOS_COMPANY=
IBCOS_DEPOT=
